# Environment the FastAPI backend needs when run against the compose stack
# (e2e/docker-compose.langfuse.yml). Sourced by `make up` and run-api.sh.
# The OpenAI key lives in app/agent/.env (gitignored).

# ── OpenTelemetry → Langfuse ────────────────────────────────────────────────
export ENABLE_OTEL=true
export ENABLE_INSTRUMENTATION=true
export ENABLE_SENSITIVE_DATA=true          # capture prompts/responses — dev only
export OTEL_SERVICE_NAME=contract-triage-api
export OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:3001/api/public/otel/v1/traces
export OTEL_EXPORTER_OTLP_TRACES_PROTOCOL=http/protobuf
# The Agent Framework's env-based exporter path defaults to gRPC unless the
# generic (non signal-suffixed) protocol var is also set — Langfuse is HTTP-only.
export OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
export OTEL_EXPORTER_OTLP_TRACES_HEADERS="Authorization=Basic cGstbGYtY29udHJhY3QtdHJpYWdlOnNrLWxmLWNvbnRyYWN0LXRyaWFnZQ=="

# ── Contract document store (the app-facing MinIO in compose, host :9092) ───
export CONTRACT_STORE_ENDPOINT=localhost:9092
export CONTRACT_STORE_ACCESS_KEY=contract-store
export CONTRACT_STORE_SECRET_KEY=contract-store-secret
export CONTRACT_STORE_BUCKET=contracts
export CONTRACT_STORE_SECURE=false
export CONTRACT_STORE_SEED_DIR=../../data/test
export TRIAGE_DB_PATH=.data/triage.db
export CONTRACT_UPLOAD_DIR=.data/uploads

export PORT=8000
