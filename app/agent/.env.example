# Contract-triage agent — configuration.
# The agent is fully LLM-first: the model makes the classification, POL-* gate and
# redline→playbook decisions plus the reviewer explanation. A chat client is
# REQUIRED — set one below, or the triage nodes raise LLMUnavailableError. (The
# test suite substitutes a deterministic double, so it needs no key.)

# ── OpenAI ───────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o

# ── Azure OpenAI (alternative) ──────────────────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_CHAT_MODEL=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_API_KEY=...

# ── Seeding + ports (`make up` sets ports via e2e/stack.env; defaults shown) ──
# SEED_EXAMPLES=1      # load the 10 demo contracts on boot (inbox ships empty)
# TRIAGE_EAGER=1       # with SEED_EXAMPLES, eagerly triage them to warm the queues
# PORT=8000            # FastAPI backend
# DEVUI_PORT=8080      # Agent Framework DevUI

# ── Observability → Langfuse (`make up` injects these via e2e/stack.env) ──
# `make up` runs a self-hosted Langfuse and wires the vars below so every triage
# run is traced (agent invocation → LLM chat → tool calls). Set them manually
# only when running the backend standalone — point at your own Langfuse
# (self-hosted or Cloud) and use that project's keys.
# ENABLE_OTEL=true
# OTEL_SERVICE_NAME=contract-triage-api
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:3001/api/public/otel/v1/traces
# OTEL_EXPORTER_OTLP_TRACES_PROTOCOL=http/protobuf   # Langfuse is HTTP-only (no gRPC)
# OTEL_EXPORTER_OTLP_TRACES_HEADERS=Authorization=Basic <base64(publicKey:secretKey)>
# ENABLE_SENSITIVE_DATA=true                          # capture prompts/responses — dev only
