# Contract-triage agent — configuration.
# The workflow runs fully offline (deterministic heuristics) with NO keys set.
# Add a chat client below to enable the LLM refinement + natural-language
# explanations, and to surface the helper agents in DevUI.

# ── OpenAI ───────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Azure OpenAI (alternative) ──────────────────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_CHAT_MODEL=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_API_KEY=...

# ── Ports (Aspire injects these; defaults shown) ────────────────────────
# PORT=8000            # FastAPI backend
# DEVUI_PORT=8080      # Agent Framework DevUI
# TRIAGE_EAGER=1       # triage the whole inbox on startup to populate queues

# ── Observability → Langfuse (Aspire injects these; see apphost/apphost.mts) ──
# The Aspire AppHost runs a self-hosted Langfuse and wires the vars below so
# every triage run is traced (agent invocation → LLM chat → tool calls). Set
# them manually only when running without Aspire (Option B) — point at your own
# Langfuse (self-hosted or Cloud) and use that project's keys.
# ENABLE_OTEL=true
# OTEL_SERVICE_NAME=contract-triage-api
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:3001/api/public/otel/v1/traces
# OTEL_EXPORTER_OTLP_TRACES_PROTOCOL=http/protobuf   # Langfuse is HTTP-only (no gRPC)
# OTEL_EXPORTER_OTLP_TRACES_HEADERS=Authorization=Basic <base64(publicKey:secretKey)>
# ENABLE_SENSITIVE_DATA=true                          # capture prompts/responses — dev only
